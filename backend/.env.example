# Copy to .env for local (non-Docker) runs. Docker Compose injects these directly.
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database — when unset, the app falls back to SQLite (handy for tests/quick runs).
# Docker Compose sets these to point at the postgres service.
POSTGRES_DB=flow
POSTGRES_USER=flow
POSTGRES_PASSWORD=flow
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Frontend origin(s) allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

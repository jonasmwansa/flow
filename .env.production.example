# Production environment for flow.useintelly.com.
#
# On the VPS:  cp .env.production.example .env  &&  chmod 600 .env  &&  edit.
# Docker Compose auto-loads this .env for ${VAR} substitution AND injects it into
# the backend container (env_file). Keep this file only on the server.

# --- Django ----------------------------------------------------------------
DEBUG=False
# Generate: python3 -c 'import secrets; print(secrets.token_urlsafe(64))'
SECRET_KEY=replace-with-a-long-random-string
ALLOWED_HOSTS=flow.useintelly.com
# Origins trusted for POSTs to the Django /admin/ over HTTPS.
CSRF_TRUSTED_ORIGINS=https://flow.useintelly.com
# SPA origin allowed to call the API (same origin here; harmless to keep).
CORS_ALLOWED_ORIGINS=https://flow.useintelly.com

# --- Database (internal Docker network — host is the "db" service) ----------
POSTGRES_DB=flow
POSTGRES_USER=flow
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Frontend build --------------------------------------------------------
# Base URL the React app calls. Same origin as the deployed site.
VITE_API_BASE_URL=https://flow.useintelly.com

# --- Host port (must be unique per site on the shared VPS) -----------------
# UseIntelly already uses 8000/8001; Flow takes 8010.
WEB_BIND_PORT=8010

# --- Optional gunicorn tuning ----------------------------------------------
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=120
# Turn on HSTS only after HTTPS is confirmed stable (seconds, e.g. 31536000).
# SECURE_HSTS_SECONDS=0
